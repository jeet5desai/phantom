# AgentKey API Configuration
# Copy this file to .env and fill in your values.

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agentkey

# Redis (optional in dev — falls back to DB-only checks)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Secrets (CHANGE THESE IN PRODUCTION!)
API_KEY_SECRET=dev-secret-change-me-in-production
VAULT_ENCRYPTION_KEY=dev-vault-key-change-me-in-production
